{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://REPLACE-WITH-BACKEND-DOMAIN/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://REPLACE-WITH-BACKEND-DOMAIN/uploads/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
