// TishkiArami catalog admin - data model
// Multilingual (en/ar/ku) via dedicated translation tables for clean search & integrity.
// Images modeled with real foreign keys + cascade so no orphan rows remain on delete.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; rhel-openssl for the Vercel/AWS serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Locale {
  EN
  AR
  KU
}

enum CategoryType {
  PRODUCT
  SERVICE
  BLOG
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// RBAC: User / Role / Permission
// ---------------------------------------------------------------------------

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique // e.g. "product.create"
  group       String // e.g. "product" - used to render permission UI in groups
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())

  @@index([group])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false) // system roles cannot be deleted
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  isActive     Boolean  @default(true)
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  blogs        Blog[]
  tokenVersion Int      @default(0) // bump to invalidate all refresh tokens for the user
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([roleId])
}

// ---------------------------------------------------------------------------
// Categories (shared by Products, Services, Blogs via `type`)
// ---------------------------------------------------------------------------

model Category {
  id        String       @id @default(cuid())
  slug      String       @unique
  type      CategoryType @default(PRODUCT)
  parentId  String?
  parent    Category?    @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[]   @relation("CategoryTree")

  // single optional image with generated variants
  imagePath          String?
  imageWebpPath      String?
  imageThumbPath     String?
  imageThumbWebpPath String?

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  translations CategoryTranslation[]
  products     Product[]
  services     Service[]
  blogs        Blog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([parentId])
}

model CategoryTranslation {
  id          String   @id @default(cuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale      Locale
  name        String
  description String?

  @@unique([categoryId, locale])
  @@index([name])
}

// ---------------------------------------------------------------------------
// Brands
// ---------------------------------------------------------------------------

model Brand {
  id      String  @id @default(cuid())
  slug    String  @unique
  website String?

  logoPath          String?
  logoWebpPath      String?
  logoThumbPath     String?
  logoThumbWebpPath String?

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  translations BrandTranslation[]
  products     Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandTranslation {
  id          String @id @default(cuid())
  brandId     String
  brand       Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  locale      Locale
  name        String
  description String?

  @@unique([brandId, locale])
  @@index([name])
}

// ---------------------------------------------------------------------------
// Products (first fully-implemented module)
// ---------------------------------------------------------------------------

model Product {
  id         String        @id @default(cuid())
  slug       String        @unique
  sku        String?       @unique
  categoryId String
  category   Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId    String?
  brand      Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  status     PublishStatus @default(DRAFT)
  isFeatured Boolean       @default(false)
  sortOrder  Int           @default(0)
  price      Decimal?      @db.Decimal(12, 2)
  currency   String        @default("USD")

  translations ProductTranslation[]
  images       ProductImage[]
  variants     ProductVariant[]
  projects     Project[]            @relation("ProductProjects")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([isFeatured])
}

// A purchasable/showable variation of a product (e.g. "Red / 60W").
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String?
  price     Decimal? @db.Decimal(12, 2)
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  // Custom attributes are stored as real rows (key + value columns), NOT JSON.
  attributes ProductVariantAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductVariantAttribute {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  key       String
  value     String
  sortOrder Int            @default(0)

  // One value per key within a variant.
  @@unique([variantId, key])
  @@index([variantId])
}

model ProductTranslation {
  id               String  @id @default(cuid())
  productId        String
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale           Locale
  name             String
  shortDescription String?
  description      String?
  metaTitle        String?
  metaDescription  String?

  @@unique([productId, locale])
  @@index([name])
}

model ProductImage {
  id                 String  @id @default(cuid())
  productId          String
  product            Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  path               String // original optimized file (relative to upload dir)
  webpPath           String
  thumbnailPath      String
  thumbnailWebpPath  String
  mimeType           String
  sizeBytes          Int
  width              Int
  height             Int
  isCover            Boolean @default(false)
  sortOrder          Int     @default(0)
  altText            String?

  createdAt DateTime @default(now())

  @@index([productId])
}

// ---------------------------------------------------------------------------
// Projects (portfolio) - schema only for now, controllers follow Products
// ---------------------------------------------------------------------------

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  clientName  String?
  location    String?
  completedAt DateTime?
  status      PublishStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  sortOrder   Int           @default(0)

  translations ProjectTranslation[]
  images       ProjectImage[]
  products     Product[]            @relation("ProductProjects")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ProjectTranslation {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  locale      Locale
  title       String
  description String?

  @@unique([projectId, locale])
  @@index([title])
}

model ProjectImage {
  id                String  @id @default(cuid())
  projectId         String
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  path              String
  webpPath          String
  thumbnailPath     String
  thumbnailWebpPath String
  mimeType          String
  sizeBytes         Int
  width             Int
  height            Int
  isCover           Boolean @default(false)
  sortOrder         Int     @default(0)
  altText           String?

  createdAt DateTime @default(now())

  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Services - schema only for now
// ---------------------------------------------------------------------------

model Service {
  id         String   @id @default(cuid())
  slug       String   @unique
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  imagePath          String?
  imageWebpPath      String?
  imageThumbPath     String?
  imageThumbWebpPath String?

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  translations ServiceTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model ServiceTranslation {
  id          String  @id @default(cuid())
  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  locale      Locale
  name        String
  description String?

  @@unique([serviceId, locale])
  @@index([name])
}

// ---------------------------------------------------------------------------
// Blogs - schema only for now
// ---------------------------------------------------------------------------

model Blog {
  id         String        @id @default(cuid())
  slug       String        @unique
  categoryId String?
  category   Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId   String?
  author     User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)

  coverPath          String?
  coverWebpPath      String?
  coverThumbPath     String?
  coverThumbWebpPath String?

  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?
  viewsCount  Int           @default(0)

  translations BlogTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
}

model BlogTranslation {
  id      String  @id @default(cuid())
  blogId  String
  blog    Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  locale  Locale
  title   String
  excerpt String?
  content String?

  @@unique([blogId, locale])
  @@index([title])
}

// ---------------------------------------------------------------------------
// Contact submissions
// ---------------------------------------------------------------------------

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_submissions")
  @@index([createdAt])
  @@index([isRead])
}
